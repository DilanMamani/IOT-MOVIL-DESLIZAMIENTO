{
  "expo": {
    "name": "mobile",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon1.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#442D1C",
        "foregroundImage": "./assets/android-icon-foregroundO.png",
        "backgroundImage": "./assets/android-icon-backgroundO.png",
        "monochromeImage": "./assets/android-icon-monochromeO.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.mobile",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-font",
      "expo-image",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "TerraGuard necesita tu ubicación para adjuntarla a tus reportes de incidentes."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "TerraGuard necesita acceso a tus fotos para adjuntarlas a los reportes.",
          "cameraPermission": "TerraGuard necesita la cámara para fotografiar incidentes."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "5809236a-964b-4540-905d-5bb312676ebd"
      }
    }
  }
}
